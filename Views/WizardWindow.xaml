<Window x:Class="MasselGUARD.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [WizardTitle], Source={x:Static local:Lang.Instance}}"
        Width="480" Height="420"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="{Binding [WizardTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="16,0"/>
                </Grid>
            </Border>

            <!-- Step indicator -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,14,0,0">
                <Ellipse x:Name="Dot0" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource Accent}"/>
                <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot4" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot5" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
            </StackPanel>

            <!-- Step pages -->
            <Grid Grid.Row="2" Margin="32,20,32,0">

                <!-- Step 0: Welcome -->
                <StackPanel x:Name="Step0">
                    <TextBlock Text="{Binding [WizardWelcomeTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding [WizardWelcomeBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>

                <!-- Step 1: Language -->
                <StackPanel x:Name="Step1" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardLangTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding [WizardLangBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,16"/>
                    <ComboBox x:Name="WizLangPicker" FontSize="11" Padding="6,4"
                              SelectionChanged="WizLang_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource Accent}"
                                            CornerRadius="2" Padding="4,1" Margin="0,0,7,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Code}"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WindowBg}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{DynamicResource Theme.FontFamily}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Step 2: Mode -->
                <StackPanel x:Name="Step2" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardModeTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding [WizardModeBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,14"/>
                    <RadioButton x:Name="WizModeStandalone" GroupName="WizMode" Checked="WizMode_Changed"
                                 Style="{StaticResource ModeRadio}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding [ModeStandaloneLabel], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding [ModeStandaloneDesc], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="WizModeCompanion" GroupName="WizMode" Checked="WizMode_Changed"
                                 Style="{StaticResource ModeRadio}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding [ModeCompanionLabel], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding [ModeCompanionDesc], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="WizModeMixed" GroupName="WizMode" Checked="WizMode_Changed"
                                 Style="{StaticResource ModeRadio}">
                        <StackPanel>
                            <TextBlock Text="{Binding [ModeMixedLabel], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding [ModeMixedDesc], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Inline status: DLL / WireGuard readiness for chosen mode -->
                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="3" Padding="10,7" Margin="0,12,0,0">
                        <TextBlock x:Name="ModeStatusLabel"
                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Step 3: Automation / manual mode -->
                <StackPanel x:Name="Step3" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardManualTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding [WizardManualBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="18"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding [SettingsModeLabel], Source={x:Static local:Lang.Instance}}"
                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ToggleButton x:Name="WizManualToggle"
                                      Width="44" Height="22"
                                      Style="{StaticResource ToggleSwitch}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Step 4: WiFi & LAN rules intro -->
                <StackPanel x:Name="Step4" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardRulesTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding [WizardRulesBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,14"/>
                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="3" Padding="12,10">
                        <StackPanel>
                            <TextBlock FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6">
                                <Run FontWeight="Bold" Text="WiFi Rules  "/>
                                <Run Foreground="{DynamicResource TextMuted}" Text="{Binding [WizardRulesWifiHint], Source={x:Static local:Lang.Instance}}"/>
                            </TextBlock>
                            <TextBlock FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6">
                                <Run FontWeight="Bold" Text="LAN Rules  "/>
                                <Run Foreground="{DynamicResource TextMuted}" Text="{Binding [WizardRulesLanHint], Source={x:Static local:Lang.Instance}}"/>
                            </TextBlock>
                            <TextBlock FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                       Foreground="{DynamicResource TextPrimary}">
                                <Run FontWeight="Bold" Text="Default Action  "/>
                                <Run Foreground="{DynamicResource TextMuted}" Text="{Binding [WizardRulesDefaultHint], Source={x:Static local:Lang.Instance}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 5: Done + About -->
                <StackPanel x:Name="Step5" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardDoneTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Success}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding [WizardDoneBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,16"/>

                    <!-- Version + update card -->
                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="{DynamicResource Theme.CornerRadius}" Padding="12,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="WizVersionLabel"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="WizUpdateStatusLabel"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <TextBlock x:Name="WizLastCheckedLabel"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="WizCheckUpdateBtn"
                                        Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,5"
                                        Margin="10,0,0,0" VerticalAlignment="Top"
                                        Click="WizCheckUpdate_Click"/>
                            </Grid>
                            <Separator Margin="0,8" Background="{DynamicResource BorderColor}" Height="1" BorderThickness="0"/>
                            <TextBlock Text="by Harold Masselink"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                       Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Text="github.com/masselink/MasselGUARD"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                       Foreground="{DynamicResource Accent}"
                                       Cursor="Hand" TextDecorations="Underline"
                                       MouseLeftButtonUp="WizGithubLink_Click"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Navigation bar -->
            <Border Grid.Row="3" Background="{DynamicResource Surface}" CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <Grid Margin="16,0">
                    <Button x:Name="BtnSkip" HorizontalAlignment="Left"
                            Content="{Binding [WizardBtnSkip], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="12,6"
                            VerticalAlignment="Center" Click="Skip_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnBack"
                                Content="{Binding [WizardBtnBack], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource FlatBtn}" FontSize="10" Padding="14,6"
                                Margin="0,0,8,0" IsEnabled="False" Click="Back_Click"/>
                        <Button x:Name="BtnNext"
                                Content="{Binding [WizardBtnNext], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource PrimaryBtn}" FontSize="10" Padding="14,6"
                                Click="Next_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
